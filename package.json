{
  "name": "syncmaster",
  "description": "Программа для синхронизации сериалов и видео с созданием отчётов",
  "version": "1.0.5",
  "type": "module",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/orion55/syncmaster.git"
  },
  "keywords": [
    "синхронизация",
    "сериалы",
    "видео",
    "отчёты"
  ],
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "npx tsx src/index.ts",
    "menu": "npx tsx src/menu-editor.ts",
    "build:sync": "ncc build src/index.ts -o dist -m",
    "build:menu": "ncc build src/menu-editor.ts -o dist/menubuild -m && move-file dist/menubuild/index.js dist/menu.js && rimraf dist/menubuild",
    "build:all": "npm run build:sync && npm run build:menu"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/ansi-colors": "^3.2.6",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^20.19.39",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "move-file-cli": "^3.0.0",
    "prettier": "3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "ansi-colors": "^4.1.3",
    "cfonts": "^3.3.1",
    "cli-progress": "^3.12.0",
    "dayjs": "^1.11.20",
    "dotenv": "^16.6.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.8.3"
  }
}
